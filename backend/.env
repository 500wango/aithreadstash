# Database
DATABASE_URL=postgresql://postgres:740135@localhost:5432/aithreadstash

# JWT
JWT_SECRET=dev-jwt-secret-key-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Server
PORT=3002
NODE_ENV=development

# Encryption
ENCRYPTION_KEY=dev-encryption-key-for-notion-tokens

# Stripe Payments (test mode)
STRIPE_SECRET_KEY=sk_test_your_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_monthly_test_id
STRIPE_PRICE_ID_YEARLY=price_yearly_test_id